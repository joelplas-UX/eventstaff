rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users kunnen eigen doc lezen/schrijven (tenantId + role koppeling)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Assignment-bevestigingstokens (één-klik bevestiging vanuit e-mail)
    // Token zelf is het geheim; Admin SDK maakt en verwijdert ze server-side
    match /assignmentTokens/{token} {
      allow create: if request.auth != null;  // planner maakt token aan
      allow read, delete: if true;             // function leest/verwijdert zonder auth
    }

    // Magic link tokens (wachtwoordloos inloggen)
    // Admin SDK maakt en verwijdert ze server-side
    match /magicTokens/{token} {
      allow read, delete: if true;             // function leest/verwijdert zonder auth
      allow create: if false;                  // alleen Admin SDK schrijft hier
    }

    // Tenant root + subcollecties
    match /tenants/{tenantId} {
      // Tenant doc: lezen als je lid bent, aanmaken als je ingelogd bent (onboarding)
      allow read:   if isMember(tenantId);
      allow create: if request.auth != null;
      allow update: if isMember(tenantId);
      allow delete: if false; // Alleen superadmin via console

      // Alle subcollecties: toegankelijk voor tenantleden
      match /{collection}/{docId} {
        allow read, write: if isMember(tenantId);
      }
    }

    function isMember(tenantId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }
  }
}
